# Screenshot to JSON - Environment Configuration
# Copy this file to .env and fill in your API keys
#
# SETUP: cp .env.example .env && nano .env

# =============================================================================
# API PROVIDERS - Choose ONE (or both for fallback)
# =============================================================================

# -----------------------------------------------------------------------------
# Option 1: OpenRouter (RECOMMENDED - Best Quality)
# -----------------------------------------------------------------------------
# Sign up: https://openrouter.ai
# Get key: https://openrouter.ai/keys
# Pricing: ~$0.01-0.02 per screenshot
#
# Models used:
#   - Vision: qwen/qwen2.5-vl-72b-instruct (best for dense UI extraction)
#   - Reasoning: qwen/qwen2.5-72b-instruct (text-only refinement pass)
#
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# -----------------------------------------------------------------------------
# Option 2: Groq (FREE TIER - Faster but Less Accurate)
# -----------------------------------------------------------------------------
# Sign up: https://console.groq.com
# Get key: https://console.groq.com/keys
# Pricing: Free tier available, then pay-as-you-go
#
# Models used:
#   - Vision (quality): meta-llama/llama-4-maverick-17b-128e-instruct
#   - Vision (fast): meta-llama/llama-4-scout-17b-16e-instruct
#   - Reasoning: llama-3.3-70b-versatile
#
GROQ_API_KEY=gsk_your-key-here

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# Which provider to use. Set in config.py:
#   provider: str = "openrouter"  # or "groq"
#
# Default is "openrouter" for best quality results.

# =============================================================================
# OPTIONAL
# =============================================================================

# Custom Python path (defaults to ./venv/bin/python3)
# PYTHON_PATH=/usr/bin/python3
